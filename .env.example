# Kakao Maps JavaScript API key
# https://developers.kakao.com/console/app -> 앱 선택 -> 플랫폼 -> Web -> 사이트 도메인에 http://localhost:5173 추가
# JavaScript 키를 아래에 붙여넣고 .env로 복사하세요.
VITE_KAKAO_MAP_KEY=

# Seoul Open Data Plaza API 키 (실시간 지하철 위치)
# https://data.seoul.go.kr -> 인증키 신청 -> 일반 인증키
VITE_SEOUL_OPENAPI_KEY=

# (선택) 별도 백엔드를 사용할 때만 설정. 비워두면 서울시 OpenAPI를 vite proxy로 직접 호출합니다.
VITE_SEOUL_NOW_API_BASE_URL=
